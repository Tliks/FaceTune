/* Container */
#general-controls-container {
    padding: var(--main-gap);
}

#targeting-container {
    flex-direction: row;
    margin-bottom: var(--main-gap);
}

#target-renderer-field {
    flex: 1;
    margin-right: 2px;
}

#targeting-object-field {
    flex: 1;
}

/* Action Buttons (Save, Undo, Redo) */
#top-actions-container {
    flex-direction: row;
}

.top-action-button {
    flex: 1;
    margin: 0 1px;
    height: var(--element-height);
    flex-direction: row;
    justify-content: center;
    align-items: center;
}

#save-button {
    flex: 3;
}

#undo-button, #redo-button, #restore-initial-overrides-button, #restore-edited-overrides-button {
    flex: 1;
}

.top-action-button Image {
    width: 16px;
    height: 16px;
}

#clip-import-container {
    flex-direction: row;
    align-items: center;
    margin-bottom: var(--main-gap);
}

#clip-import-label {
    flex: 0 0 auto;
    margin-right: var(--main-gap);
}

#clip-field-container {
    flex: 1 1 auto;
    margin-right: var(--main-gap);
}

#import-option-field-container {
    flex: 0 0 120px;
}

.clip-import-field {
    flex: 1 1 auto;
    margin: 0px;
}

#content-container {
    padding: var(--main-gap);
    background-color: rgba(0, 0, 0, 0.1);
    border-radius: 4px;
}

#filter-header {
    flex-direction: row;
    margin-bottom: var(--main-gap);
}

#all-button, #none-button {
    flex: 0 0 30px;
    padding: 0;
    margin-right: 2px;
}

#left-toggle, #right-toggle {
    padding: 0;
    margin-right: 2px;
}


#group-toggles-container {
    flex-direction: row;
    flex-wrap: wrap;
}

.group-toggle {
    padding: 0px;
}
